#!/command/with-contenv bashio
# Telnet operator console — a live switchboard board an operator drives over
# telnet (ring a room, connect two rooms, hang up). host_network exposes the
# port on the LAN, so `telnet <host> <port>` reaches it directly.
# Idle ONLY on an explicit `false`. bashio can momentarily read blank options at
# boot; `bashio::config.true` treats that empty read as false and would then
# PERMANENTLY idle this enabled-by-default service (s6 never restarts an idle
# process). Key off the literal value so an empty/transient read runs.
if [ "$(bashio::config 'console_enabled')" = "false" ]; then
    bashio::log.info "Operator console disabled (console_enabled: false); idling."
    exec sleep infinity
fi

PORT="$(bashio::config 'console_port')"
BIND="$(bashio::config 'console_bind')"
bashio::log.info "Starting Switchboard operator console on ${BIND}:${PORT} ..."
bashio::log.notice "The operator console is UNAUTHENTICATED on the LAN and can ring/connect/hang up phones. Set console_bind to 127.0.0.1 to restrict it, or console_enabled:false to turn it off."

if [ -f /run/switchboard/ami.env ]; then
    # shellcheck disable=SC1091
    source /run/switchboard/ami.env
    export AMI_USER AMI_SECRET
fi

export CONSOLE_PORT="${PORT}"
export CONSOLE_HOST="${BIND}"
# Timezone backstop: the init step points /etc/localtime at the resolved zone,
# but also export TZ so the board clock is right even if the symlink didn't take.
export TZ="$(cat /run/switchboard/tz 2>/dev/null || echo UTC)"
cd /usr/share/switchboard/console || exit 1
exec python3 console.py

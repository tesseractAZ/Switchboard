#!/command/with-contenv bashio
# Resident whisper.cpp recognizer. Keeps the ~142 MB base.en model loaded in RAM
# and serves transcription over a loopback HTTP endpoint, so switchboard-stt no
# longer reloads the whole model from disk on every single utterance (dial-0
# operator, 42 wake-up, 43 automation). switchboard-stt POSTs the recording here
# and transparently falls back to the whisper-cli subprocess if this server is
# down or still loading — so this service is never on the critical path for a
# call, and nothing depends on it.

# One-flip rollback: stt_resident:false idles this longrun; switchboard-stt then
# gets connection-refused and reverts to the exact whisper-cli path, no code
# coordination needed.
# Idle only on an explicit `false` — an empty/transient bashio read at boot must not
# permanently idle the enabled-by-default resident recognizer (a transient idle would
# force the slower whisper-cli path until the next restart).
if [ "$(bashio::config 'stt_resident')" = "false" ]; then
    bashio::log.info "stt_resident:false — resident recognizer disabled; idling (whisper-cli per call)."
    exec sleep infinity
fi

# RAM gate: don't hold ~150 MB resident when NO speech feature is enabled. EVERY
# feature that shells out to switchboard-stt is a consumer — operator (dial 0,
# --mode rooms), wake-up (42, --mode time), automation (43), dial-a-status (45),
# announce (46) and directory assistance (411), all --mode transcribe. Each
# toggles independently; miss any one and that feature silently falls back to the
# slow per-call whisper-cli, which can blow the 25 s AGI timeout. Keep this list
# in lockstep with the AGIs that call sp.listen / switchboard-stt.
# Idle ONLY when EVERY speech feature reads an explicit literal "false" — never
# on a blank/absent read. bashio can momentarily return "" during a config reload
# or at boot; `! bashio::config.true` treats "" as "not enabled", so a transient
# all-blank read would satisfy every clause and PERMANENTLY idle the recognizer
# even with features enabled (s6 sees the idle process as "started" and never
# restarts it — the v0.30.1 console-web regression, same class). `= "false"` makes
# a blank read fall through to "stay resident", which is the safe default.
if [ "$(bashio::config 'operator.enabled')" = "false" ] \
   && [ "$(bashio::config 'wakeup_enabled')" = "false" ] \
   && [ "$(bashio::config 'automation_enabled')" = "false" ] \
   && [ "$(bashio::config 'status_enabled')" = "false" ] \
   && [ "$(bashio::config 'announce_enabled')" = "false" ] \
   && [ "$(bashio::config 'directory_enabled')" = "false" ]; then
    bashio::log.info "No STT feature enabled (operator/wakeup/automation/status/announce/directory all off); whisper-server idling."
    exec sleep infinity
fi

MODEL="${SW_WHISPER_MODEL:-/usr/share/whisper/model.bin}"
if [ ! -f "${MODEL}" ]; then
    # Never crash-loop s6 — idle so switchboard-stt just uses whisper-cli.
    bashio::log.warning "whisper model ${MODEL} missing; whisper-server idling (whisper-cli fallback active)."
    exec sleep infinity
fi

PORT="${SW_WHISPER_PORT:-8126}"
THREADS="$(nproc 2>/dev/null || echo 2)"
[ "${THREADS}" -gt 4 ] 2>/dev/null && THREADS=4   # match the CLI's min(4,cpu)

bashio::log.info "Starting resident whisper-server on 127.0.0.1:${PORT} (model ${MODEL}, ${THREADS} threads) ..."
# Bind LOOPBACK ONLY — host_network=true means 0.0.0.0 would expose an
# unauthenticated inference server on the LAN. Run as the unprivileged asterisk
# uid (only reads a world-readable model + binds a high loopback port). s6
# auto-restarts on crash; the gap is covered by the whisper-cli fallback.
exec s6-setuidgid asterisk \
    /usr/bin/whisper-server \
        --model "${MODEL}" \
        --host 127.0.0.1 \
        --port "${PORT}" \
        --threads "${THREADS}" \
        --beam-size 1 \
        --language en

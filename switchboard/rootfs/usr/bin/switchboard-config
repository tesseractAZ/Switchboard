#!/usr/bin/python3
"""Render Asterisk configuration for Switchboard from the add-on options.

The add-on options (/data/options.json) are the single source of truth. On every
start we regenerate /etc/asterisk/{pjsip,extensions,rtp,manager,logger}.conf so
the running PBX always matches the declared config.

Design notes
------------
* PJSIP only. chan_sip is removed in modern Asterisk; every endpoint and the
  optional trunk are res_pjsip.
* Analog FXS ports register *to* us, so each room is a PJSIP endpoint with a
  dynamic AOR and inbound auth.
* G.711 µ-law only, everywhere. Every endpoint (rooms + trunk) is pinned to
  ``allow = ulaw`` so no call ever transcodes — µ-law is the baseline the analog
  FXS ports, the cordless, the softphone, and the PSTN trunk all speak, and HD
  codecs carry no extra fidelity from an antique analog handset anyway.
* AMI is bound to 127.0.0.1 only and used by the Ingress UI for live status.
"""

from __future__ import annotations

import json
import os
import re
import secrets
import string
from pathlib import Path

OPTIONS_PATH = Path("/data/options.json")
ASTERISK_ETC = Path("/etc/asterisk")
RUN_DIR = Path("/run/switchboard")
# Persistent JSON stores (wake-ups, MWI flags) that BOTH the root services AND
# asterisk-user processes write — see ensure_state_dir().
DATA_DIR = Path("/data")
STATE_DIR = DATA_DIR / "state"

# G.711 µ-law is the ONLY codec — every endpoint renders `allow = ulaw`, so no
# call transcodes. This is deliberate and not configurable (see module docstring).
CODEC_ALLOW = "ulaw"


def log(msg: str) -> None:
    print(f"[switchboard-config] {msg}", flush=True)


def load_options() -> dict:
    if not OPTIONS_PATH.exists():
        log(f"WARNING: {OPTIONS_PATH} missing; using empty defaults")
        return {}
    try:
        with OPTIONS_PATH.open() as fh:
            return json.load(fh)
    except (OSError, ValueError) as exc:
        # A malformed options.json must not crash the init oneshot (which would
        # silently take the whole add-on down); degrade to empty defaults + log.
        log(f"ERROR: cannot read/parse {OPTIONS_PATH}: {exc}; using empty defaults")
        return {}


# --------------------------------------------------------------------------- #
# Timezone — the talking clock / wake-up calls must speak LOCAL time, but the
# add-on container runs in UTC. Resolve a zone (explicit option > the Home
# Assistant timezone via the Supervisor > UTC) and point /etc/localtime at it,
# so Asterisk's SayUnixTime and every Python service read local time with no
# per-process TZ plumbing.
# --------------------------------------------------------------------------- #
def resolve_timezone(opts: dict) -> str:
    tz = str(opts.get("timezone", "") or "").strip()
    if tz:
        return tz
    token = os.environ.get("SUPERVISOR_TOKEN", "")
    if token:
        import urllib.request
        # `supervisor` is the Docker-internal DNS name (works for bridge-network
        # add-ons); 172.30.32.2 is the Supervisor's fixed IP, reachable from a
        # host_network add-on (where the `supervisor` name doesn't resolve). Try
        # both so auto-detect works regardless of the add-on's network mode.
        for host in ("http://supervisor", "http://172.30.32.2"):
            try:
                req = urllib.request.Request(
                    f"{host}/info", headers={"Authorization": f"Bearer {token}"}
                )
                data = json.loads(urllib.request.urlopen(req, timeout=5).read().decode())
                tz = ((data.get("data") or {}).get("timezone") or "").strip()
                if tz:
                    log(f"timezone: auto-detected {tz} from Home Assistant ({host})")
                    return tz
            except Exception as exc:  # network/permission/parse — try next, don't crash
                log(f"timezone: lookup via {host} failed ({exc})")
    return "UTC"


def apply_timezone(tz: str) -> str:
    """Point /etc/localtime at the resolved zone. Returns the zone actually
    applied (UTC if the requested one isn't in tzdata)."""
    zoneinfo = Path("/usr/share/zoneinfo") / tz
    if not zoneinfo.exists():
        log(f"timezone: {tz!r} not found in zoneinfo; staying on UTC")
        return "UTC"
    try:
        localtime = Path("/etc/localtime")
        if localtime.is_symlink() or localtime.exists():
            localtime.unlink()
        localtime.symlink_to(zoneinfo)
        Path("/etc/timezone").write_text(tz + "\n")
        log(f"timezone set to {tz}")
        return tz
    except OSError as exc:
        log(f"timezone: could not set {tz} ({exc}); staying on UTC")
        return "UTC"


def gen_secret(n: int = 24) -> str:
    alphabet = string.ascii_letters + string.digits
    return "".join(secrets.choice(alphabet) for _ in range(n))


def _int(value: object, default: int) -> int:
    """Coerce to int, falling back to a default rather than crashing on junk."""
    try:
        return int(value)  # type: ignore[arg-type]
    except (TypeError, ValueError):
        return default


_CONTROL_RE = re.compile(r"[\x00-\x1f\x7f]")


def _has_control(value: str) -> bool:
    """True if value has CR/LF or other control chars (config-injection risk)."""
    return bool(_CONTROL_RE.search(value))


def _scrub(value: str) -> str:
    """Strip control chars so a value can't break out of its .conf line/section."""
    return _CONTROL_RE.sub("", value)


def valid_rooms(rooms: list) -> list[dict]:
    """Validate/sanitize room entries once; both renderers consume the result.

    Skips (with a secret-safe log) rooms that are missing fields, have a
    non-numeric ext, duplicate an earlier ext, or carry control characters in
    the secret — so one bad entry can't inject config or shadow another room.
    Returns dicts with cleaned ext/name/secret.
    """
    out: list[dict] = []
    seen: set[str] = set()
    for room in rooms:
        ext = str(room.get("ext", "")).strip()
        name = str(room.get("name", ext))
        sec = str(room.get("secret", ""))
        if not ext or not sec.strip():
            log(f"skipping room ext={ext!r}: missing ext or secret")
            continue
        if not re.fullmatch(r"[0-9]{2,6}", ext):
            log(f"skipping room ext={ext!r}: ext must be 2-6 digits")
            continue
        if ext in seen:
            log(f"skipping duplicate room ext={ext!r}")
            continue
        if _has_control(sec):
            log(f"skipping room ext={ext!r}: secret contains control characters")
            continue
        seen.add(ext)
        # Display name goes into a quoted callerid and a comment. Drop control
        # chars (no section break-out), the quote char (no callerid quote break),
        # and ';' (which would start an Asterisk comment mid-line and truncate
        # the callerid). Keep everything else so legit names survive (e.g. "Café").
        clean_name = _scrub(name).replace('"', "").replace(";", "").strip() or ext
        out.append({"ext": ext, "name": clean_name, "secret": sec})
    return out


def write(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    log(f"wrote {path} ({len(content)} bytes)")


# --------------------------------------------------------------------------- #
# pjsip.conf
# --------------------------------------------------------------------------- #
def render_pjsip(opts: dict) -> str:
    rooms = opts.get("rooms", []) or []
    trunk = opts.get("trunk", {}) or {}

    parts = [
        ";; GENERATED by switchboard-config — edits here are overwritten.",
        "",
        "[transport-udp]",
        "type = transport",
        "protocol = udp",
        "bind = 0.0.0.0:5060",
        "",
        ";; ----- Endpoint template shared by all room phones -----",
        "[room-endpoint](!)",
        "type = endpoint",
        "context = rooms",
        "disallow = all",             # G.711 µ-law only — no HD/Opus, no transcode
        f"allow = {CODEC_ALLOW}",
        "direct_media = no",          # keep media through Asterisk (NAT-safe on LAN)
        "rtp_symmetric = yes",
        "force_rport = yes",
        "rewrite_contact = yes",      # ATAs on the LAN; trust the source port
        "dtmf_mode = rfc4733",
        "",
        "[room-aor](!)",
        "type = aor",
        "max_contacts = 1",
        "remove_existing = yes",
        "qualify_frequency = 60",
        "",
    ]

    for room in rooms:
        # rooms have already been validated/sanitized by valid_rooms() in main().
        ext = room["ext"]
        name = room["name"]
        sec = room["secret"]
        endpoint = [
            f"[{ext}](room-endpoint)",
            "type = endpoint",
            f"auth = {ext}-auth",
            f"aors = {ext}",
            f'callerid = "{name}" <{ext}>',
        ]
        # MWI ("you have a message" stutter tone) is delivered by sending an
        # unsolicited message-summary NOTIFY straight to the contact via
        # PJSIPNotify (see render_pjsip_notify / ami.set_mwi), so the endpoint
        # needs no mailboxes= / app_voicemail / res_mwi_external wiring.
        parts += [
            f";; Room {ext} — {name}",
            f"[{ext}](room-aor)",
            "type = aor",
            "",
            f"[{ext}-auth]",
            "type = auth",
            "auth_type = userpass",
            f"username = {ext}",
            f"password = {sec}",
            "",
            *endpoint,
            "",
        ]

    if trunk.get("enabled"):
        parts += render_trunk_pjsip(trunk)

    return "\n".join(parts) + "\n"


def render_trunk_pjsip(trunk: dict) -> list[str]:
    host = _scrub(str(trunk.get("provider_host", "")).strip())
    port = _int(trunk.get("port", 5060) or 5060, 5060)
    user = _scrub(str(trunk.get("username", "")).strip())
    sec = str(trunk.get("secret", ""))
    from_user = _scrub(str(trunk.get("from_user", "") or user).strip())
    from_domain = _scrub(str(trunk.get("from_domain", "") or host).strip())
    do_register = bool(trunk.get("registns", True))

    if not host or not user:
        log("trunk enabled but provider_host/username missing — skipping trunk")
        return []
    # Fail closed on values that could inject extra PJSIP directives/sections.
    if _has_control(sec):
        log("trunk: secret contains control characters — skipping trunk")
        return []
    if not re.fullmatch(r"[A-Za-z0-9._:\-]+", host):
        log("trunk: invalid provider_host — skipping trunk")
        return []
    if not re.fullmatch(r"[A-Za-z0-9._@:\-]+", user):
        log("trunk: invalid username — skipping trunk")
        return []

    lines = [
        ";; ----- SIP trunk (outside line) -----",
        "[trunk-auth]",
        "type = auth",
        "auth_type = userpass",
        f"username = {user}",
        f"password = {sec}",
        "",
        "[trunk-aor]",
        "type = aor",
        f"contact = sip:{host}:{port}",
        # Do NOT qualify the trunk's static contact. VoIP.ms does not reliably
        # answer OPTIONS keep-alives, so qualifying flaps the contact to
        # "Unavailable" — and PJSIP then refuses to route outbound calls to it,
        # so Dial(...@trunk) fails with 503 "Service Unavailable" even while the
        # registration (and thus inbound) stays perfectly healthy. 0 disables the
        # health check so the contact is always usable for outbound; inbound
        # liveness is covered by the periodic re-REGISTER instead.
        "qualify_frequency = 0",
        "",
        "[trunk]",
        "type = endpoint",
        "context = from-trunk",
        # The outside line is the PSTN — always narrowband G.711. Pin the trunk
        # leg to µ-law so the provider can never negotiate a wideband codec and
        # force a transcode against the analog FXS phones (adds latency, no gain).
        # The room endpoints are µ-law-only too, so the whole path is one codec.
        "disallow = all",
        f"allow = {CODEC_ALLOW}",
        "outbound_auth = trunk-auth",
        "aors = trunk-aor",
        f"from_user = {from_user}",
        f"from_domain = {from_domain}",
        "direct_media = no",
        "rtp_symmetric = yes",
        "force_rport = yes",
        "rewrite_contact = yes",
        "dtmf_mode = rfc4733",
        "",
        "[trunk-identify]",
        "type = identify",
        "endpoint = trunk",
        f"match = {host}",
        "",
    ]
    if do_register:
        lines += [
            "[trunk-reg]",
            "type = registration",
            "transport = transport-udp",
            "outbound_auth = trunk-auth",
            f"server_uri = sip:{host}:{port}",
            f"client_uri = sip:{user}@{from_domain}",
            "retry_interval = 60",
            "",
        ]
    return lines


# --------------------------------------------------------------------------- #
# extensions.conf  (dial plan)
# --------------------------------------------------------------------------- #
def render_operator_context(joined: str, automation_on: bool = False,
                            mwi_on: bool = True) -> list[str]:
    """The [operator] context: dial 0 -> AGI voice operator -> validated Dial.

    The AGI only *sets* OP_RESULT/OP_TARGET; the dialplan does the Dial, and only
    to a known room ext (the ``joined`` allow-list), so a recognizer bug can
    never dial an arbitrary endpoint. The AGI plays prompts, records the caller,
    runs offline STT, and matches the speech to a room.

    When ``mwi_on``, dialing 0 also clears the caller's own message-waiting flag
    (the indicator means "call the operator", and they just did). When
    ``automation_on``, a spoken "automation" (OP_RESULT=automation) routes into
    the voice home-automation flow.
    """
    lines = [
        ";; ----- Voice operator (dial 0) -----",
        "[operator]",
        "exten = s,1,NoOp(Operator session start)",
        " same = n,Answer()",
    ]
    if mwi_on:
        # The MWI stutter-tone means "you have a message / call the operator".
        # Dialing 0 IS calling the operator, so the flag is logically superseded
        # the instant they dial 0. Clear it AFTER Answer() and background it (`&`)
        # so a wedged AMI can never delay the answered caller up to the AMI
        # timeout — a moment-later clear is identical UX with zero ring latency.
        lines += [
            " same = n,System(/usr/bin/switchboard-mwi clear ${CALLERID(num)} &)",
        ]
    lines += [
        " same = n,Set(CHANNEL(language)=en)",
        " same = n,Wait(1)",
        " same = n,AGI(switchboard-operator.agi)",
        " same = n,NoOp(operator result=${OP_RESULT} target=${OP_TARGET})",
    ]
    if automation_on:
        # A spoken "automation" enters the lights flow. Checked BEFORE the
        # connect/bye logic so it doesn't disturb the existing dial path.
        lines += [
            " same = n,GotoIf($[\"${OP_RESULT}\" = \"automation\"]?automation,s,1)",
        ]
    lines += [
        " same = n,GotoIf($[\"${OP_RESULT}\" = \"connect\"]?:bye)",
        # Defense in depth: only dial a *known room* ext, even if the AGI misbehaves.
        f" same = n,GotoIf($[\"${{OP_TARGET}}\" : \"^({joined})$\"]?:bye)",
        # Engaged-line short-circuit: if the room is already on a call, say "busy"
        # at once instead of dialing it (the gateway would call-waiting-ring a busy
        # line instead of returning busy). DEVICE_STATE is the live FXS port state.
        " same = n,Set(DS=${DEVICE_STATE(PJSIP/${OP_TARGET})})",
        " same = n,GotoIf($[\"${DS}\" = \"UNAVAILABLE\" | \"${DS}\" = \"INVALID\"]?unavail)",
        " same = n,GotoIf($[\"${DS}\" != \"NOT_INUSE\"]?busy)",
        " same = n(connect),Playback(switchboard/sw-connecting)",
        " same = n,Dial(PJSIP/${OP_TARGET},30,rtT)",
        # Dial fell through (didn't answer): tell the caller WHY rather than a
        # bland goodbye. ${DIALSTATUS} = BUSY | NOANSWER | CHANUNAVAIL | CONGESTION.
        " same = n,Verbose(0,Operator dial ${OP_TARGET} -> ${DIALSTATUS})",
        " same = n,GotoIf($[\"${DIALSTATUS}\" = \"BUSY\"]?busy)",
        " same = n,GotoIf($[\"${DIALSTATUS}\" = \"NOANSWER\"]?noanswer)",
        " same = n,GotoIf($[\"${DIALSTATUS}\" = \"CHANUNAVAIL\"]?unavail)",
        " same = n,GotoIf($[\"${DIALSTATUS}\" = \"CONGESTION\"]?unavail)",
        " same = n,Goto(bye)",
        " same = n(busy),Playback(switchboard/sw-busy)",
        " same = n,Goto(endtone)",
        " same = n(noanswer),Playback(switchboard/sw-noanswer)",
        " same = n,Goto(endtone)",
        " same = n(unavail),Playback(switchboard/sw-unavailable)",
        " same = n,Goto(endtone)",
        # Also reached after a connected call ends (Dial returns): the end-of-call
        # tone tells the caller on an antique handset that the line is down.
        " same = n(bye),Playback(switchboard/sw-goodbye)",
        " same = n(endtone),Playback(switchboard/sw-endtone)",
        " same = n,Hangup()",
        "",
    ]
    return lines


def render_wakeup_context() -> list[str]:
    """The [wakeup] context (dial the code -> AGI sets/changes/cancels a wake-up,
    then the dialplan reads it back) and [wakeup-deliver] (the scheduler service
    originates the room INTO this to actually ring it at the chosen time)."""
    return [
        ";; ----- Wake-up calls -----",
        "[wakeup]",
        "exten = s,1,NoOp(Wake-up request from ${CHANNEL})",
        " same = n,Answer()",
        " same = n,Set(CHANNEL(language)=en)",
        " same = n,Wait(1)",
        " same = n,AGI(switchboard-wakeup.agi)",
        " same = n,NoOp(wakeup result=${WAKEUP_RESULT} epoch=${WAKEUP_EPOCH})",
        " same = n,GotoIf($[\"${WAKEUP_RESULT}\" = \"set\"]?setdone)",
        " same = n,GotoIf($[\"${WAKEUP_RESULT}\" = \"cancelled\"]?cancelled)",
        " same = n,Goto(none)",
        " same = n(setdone),Playback(switchboard/sw-wakeup-set)",
        " same = n,SayUnixTime(${WAKEUP_EPOCH},,IMp)",
        " same = n,Goto(bye)",
        " same = n(cancelled),Playback(switchboard/sw-wakeup-cancelled)",
        " same = n,Goto(bye)",
        " same = n(none),Playback(switchboard/sw-wakeup-none)",
        " same = n(bye),Playback(switchboard/sw-goodbye)",
        " same = n,Playback(switchboard/sw-endtone)",
        " same = n,Hangup()",
        "",
        "[wakeup-deliver]",
        "exten = s,1,NoOp(Wake-up delivery to ${CHANNEL})",
        " same = n,Answer()",
        " same = n,Set(CHANNEL(language)=en)",
        " same = n,Wait(1)",
        " same = n,Playback(switchboard/sw-wakeup-greeting)",
        " same = n,SayUnixTime(,,IMp)",
        # Smart wake-up: fire the configured scene + speak weather / next calendar
        # event (all no-ops if unconfigured or HA is unreachable — the AGI degrades).
        " same = n,AGI(switchboard-wakeup-deliver.agi)",
        " same = n,Wait(1)",
        " same = n,Playback(switchboard/sw-wakeup-greeting)",
        " same = n,SayUnixTime(,,IMp)",
        " same = n,Hangup()",
        "",
    ]


def render_page_context() -> list[str]:
    """The [page] context: ami.page_all Originates each room INTO this, which
    drops the channel into the quiet ConfBridge intercom so the whole house
    hears (and can answer back on) the announcement."""
    return [
        ";; ----- Page intercom (conference target) -----",
        "[page]",
        "exten = s,1,NoOp(Page intercom)",
        " same = n,Answer()",
        " same = n,ConfBridge(switchboard-page,switchboard_bridge,switchboard_user)",
        " same = n,Hangup()",
        "",
    ]


def render_automation_context() -> list[str]:
    """The [automation] context: runs the voice home-automation (lights) AGI.
    Reached either by dialing automation_ext or by saying "automation" to the
    operator (which sets OP_RESULT=automation and the operator Gotos here)."""
    return [
        ";; ----- Voice home automation (lights) -----",
        "[automation]",
        "exten = s,1,NoOp(Automation)",
        " same = n,Answer()",
        " same = n,Set(CHANNEL(language)=en)",
        " same = n,Wait(1)",
        " same = n,AGI(switchboard-automation.agi)",
        " same = n,Hangup()",
        "",
    ]


def render_status_context() -> list[str]:
    """The [status] context: the dial-a-status voice menu AGI (say power / weather
    / house, or press 1/2/3, and hear live Home Assistant state spoken back)."""
    return [
        ";; ----- Dial-a-status voice menu -----",
        "[status]",
        "exten = s,1,NoOp(Status menu)",
        " same = n,Answer()",
        " same = n,Set(CHANNEL(language)=en)",
        " same = n,Wait(1)",
        " same = n,AGI(switchboard-status.agi)",
        " same = n,Hangup()",
        "",
    ]


def render_announce_context() -> list[str]:
    """The [announce] context: record a short message and play it out to the
    configured Home Assistant media players (via the announce AGI)."""
    return [
        ";; ----- Phone -> HA speaker announce -----",
        "[announce]",
        "exten = s,1,NoOp(Announce)",
        " same = n,Answer()",
        " same = n,Set(CHANNEL(language)=en)",
        " same = n,Wait(1)",
        " same = n,AGI(switchboard-announce.agi)",
        " same = n,Hangup()",
        "",
    ]


def render_outbound_rules(prefix: str, caller_id: str) -> list:
    """Outbound-via-trunk dialplan lines, emitted INSIDE the [rooms] context.

    These MUST live in [rooms] (where the phones dial from). The literal-``prefix``
    patterns (``_<prefix>011.`` / ``_<prefix>900.`` / ``_<prefix>.``) out-prioritise
    the catch-all ``_X.`` room pattern, so a prefixed number routes to the trunk
    while bare extensions still ring rooms. The toll-fraud blocks are more specific
    than the general ``_<prefix>.`` rule, so Asterisk denies them first.

    (Regression guard: when these lived after the feature contexts they landed in
    [automation], so [rooms] had no ``_9.`` — every outbound call fell through to
    ``_X.`` → "not a room" → Congestion, which phones show as "Service Unavailable".)
    """
    cid = f"Set(CALLERID(num)={caller_id})" if caller_id else "NoOp(no outbound CID)"
    plen = len(prefix)  # strip the whole prefix, not a hardcoded single char
    return [
        "",
        ";; ----- Blocked destinations (toll-fraud guard) -----",
        ";; International (011) and premium-rate (900 / 1-900) are denied. These",
        ";; patterns are more specific than the general rule below, so Asterisk",
        ";; matches them first. Everything else still dials out normally.",
        f"exten = _{prefix}011.,1,NoOp(Blocked international)",
        " same = n,Congestion(5)",
        " same = n,Hangup()",
        f"exten = _{prefix}1900.,1,NoOp(Blocked premium 1-900)",
        " same = n,Congestion(5)",
        " same = n,Hangup()",
        f"exten = _{prefix}900.,1,NoOp(Blocked premium 900)",
        " same = n,Congestion(5)",
        " same = n,Hangup()",
        "",
        ";; ----- Outbound via SIP trunk (in [rooms] so the phones can dial it) -----",
        f"exten = _{prefix}.,1,NoOp(Outbound ${{EXTEN:{plen}}})",
        f" same = n,{cid}",
        f" same = n,Dial(PJSIP/${{EXTEN:{plen}}}@trunk,60,rtT)",
        " same = n,Hangup()",
    ]


def render_extensions(opts: dict) -> str:
    rooms = opts.get("rooms", []) or []
    trunk = opts.get("trunk", {}) or {}
    # rooms are pre-validated/deduped by valid_rooms(); keep pjsip + dialplan in sync.
    exts = [r["ext"] for r in rooms]
    operator_on = bool((opts.get("operator") or {}).get("enabled", True))
    mwi_on = bool(opts.get("mwi_enabled", True))
    prefix_raw = str(trunk.get("dial_prefix", "9") or "9").strip()
    prefix = prefix_raw if re.fullmatch(r"[0-9*#]+", prefix_raw) else "9"
    if prefix != prefix_raw:
        log(f"trunk: invalid dial_prefix {prefix_raw!r}; using '9'")
    caller_id_raw = str(trunk.get("outbound_caller_id", "") or "").strip()
    caller_id = caller_id_raw if re.fullmatch(r"[0-9+]*", caller_id_raw) else ""
    if caller_id != caller_id_raw:
        log("trunk: invalid outbound_caller_id (digits/+ only); ignoring")

    parts = [
        ";; GENERATED by switchboard-config — edits here are overwritten.",
        "",
        "[general]",
        "static = yes",
        "writeprotect = yes",
        "",
        "[globals]",
        "",
        ";; ----- Room-to-room calling -----",
        "[rooms]",
    ]

    if operator_on and exts:
        # Literal '0' out-prioritizes the _X. pattern below, so ordering is safe.
        parts += [
            "exten = 0,1,NoOp(Operator requested by ${CALLERID(num)})",
            " same = n,Goto(operator,s,1)",
            "",
        ]

    # Talking clock — dial the code, hear the local time. A literal extension
    # out-prioritizes the _X. room pattern. Skipped if it collides with a room.
    clock_on = bool(opts.get("clock_enabled", True))
    clock_ext = str(opts.get("clock_ext", "41") or "41").strip()
    if clock_on and exts:
        if not re.fullmatch(r"[0-9]{2,6}", clock_ext):
            log(f"clock: invalid clock_ext {clock_ext!r}; talking clock disabled")
        elif clock_ext in exts:
            log(f"clock: clock_ext {clock_ext} collides with a room ext; talking clock disabled")
        else:
            # SayUnixTime(,,IMp): now, system (local) tz, 12h + minutes + a.m./p.m.
            parts += [
                f"exten = {clock_ext},1,NoOp(Talking clock)",
                " same = n,Answer()",
                " same = n,Set(CHANNEL(language)=en)",
                " same = n,Wait(1)",
                # Old-style speaking clock: "At the tone, the time will be …" + a pip.
                " same = n,Playback(switchboard/sw-at-the-tone)",
                " same = n,SayUnixTime(,,IMp)",
                " same = n,Playback(switchboard/sw-tone)",
                " same = n,Wait(1)",
                " same = n,Hangup()",
                "",
            ]

    # Wake-up calls — dial the code to set/change/cancel by voice. Literal
    # extension; skipped if it collides with a room or the clock.
    wakeup_on = bool(opts.get("wakeup_enabled", True))
    wakeup_ext = str(opts.get("wakeup_ext", "42") or "42").strip()
    if wakeup_on and exts:
        if not re.fullmatch(r"[0-9]{2,6}", wakeup_ext):
            log(f"wakeup: invalid wakeup_ext {wakeup_ext!r}; dial code disabled")
        elif wakeup_ext in exts or wakeup_ext == clock_ext:
            log(f"wakeup: wakeup_ext {wakeup_ext} collides with a room/clock ext; dial code disabled")
        else:
            parts += [
                f"exten = {wakeup_ext},1,NoOp(Wake-up call)",
                " same = n,Goto(wakeup,s,1)",
                "",
            ]

    # The set of literal dial codes already claimed, so each new feature code is
    # checked against rooms, '0' (operator), the ENABLED clock/wakeup codes, AND any
    # earlier feature code — never silently shadowing or being shadowed. A disabled
    # clock/wakeup doesn't reserve its ext, so another feature may reuse it.
    reserved = set(exts) | {"0"}
    if clock_on:
        reserved.add(clock_ext)
    if wakeup_on:
        reserved.add(wakeup_ext)

    # Page intercom — a phone dialing this pages the whole house duplex (Page's
    # 'd' flag = everyone can talk back). Literal extension; skipped on collision.
    page_on = bool(opts.get("page_enabled", True))
    page_ext = str(opts.get("page_ext", "44") or "44").strip()
    if page_on and exts:
        if not re.fullmatch(r"[0-9]{2,6}", page_ext):
            log(f"page: invalid page_ext {page_ext!r}; page dial code disabled")
        elif page_ext in reserved:
            log(f"page: page_ext {page_ext} collides with a reserved/room ext; page dial code disabled")
        else:
            # Ring every room duplex. Ringing the dialer's own (now busy) line is
            # harmless. Channels are PJSIP endpoints, joined with '&'.
            peers = "&".join(f"PJSIP/{e}" for e in exts)
            parts += [
                f"exten = {page_ext},1,NoOp(Page)",
                f' same = n,Set(PAGEPEERS={peers})',
                " same = n,Page(${PAGEPEERS},d)",
                " same = n,Hangup()",
                "",
            ]
            reserved.add(page_ext)

    # Voice home automation — a phone dialing this enters the lights flow.
    # Literal extension; skipped on collision with rooms/0/clock/wakeup/page.
    automation_on = bool(opts.get("automation_enabled", True))
    automation_ext = str(opts.get("automation_ext", "43") or "43").strip()
    if automation_on and exts:
        if not re.fullmatch(r"[0-9]{2,6}", automation_ext):
            log(f"automation: invalid automation_ext {automation_ext!r}; dial code disabled")
        elif automation_ext in reserved:
            log(f"automation: automation_ext {automation_ext} collides with a reserved/room ext; dial code disabled")
        else:
            parts += [
                f"exten = {automation_ext},1,NoOp(Automation)",
                " same = n,Goto(automation,s,1)",
                "",
            ]
            reserved.add(automation_ext)

    # Dial-a-status voice menu — a phone dialing this hears a menu and can ask for
    # live power / weather / house status. Literal ext; skipped on collision.
    status_on = bool(opts.get("status_enabled", True))
    status_ext = str(opts.get("status_ext", "45") or "45").strip()
    if status_on and exts:
        if not re.fullmatch(r"[0-9]{2,6}", status_ext):
            log(f"status: invalid status_ext {status_ext!r}; dial code disabled")
        elif status_ext in reserved:
            log(f"status: status_ext {status_ext} collides with a reserved/room ext; dial code disabled")
        else:
            parts += [
                f"exten = {status_ext},1,NoOp(Status menu)",
                " same = n,Goto(status,s,1)",
                "",
            ]
            reserved.add(status_ext)

    # Phone -> HA speaker announce — dialing this records a short message and plays
    # it out to the configured media players. Literal ext; skipped on collision.
    announce_on = bool(opts.get("announce_enabled", True))
    announce_ext = str(opts.get("announce_ext", "46") or "46").strip()
    if announce_on and exts:
        if not re.fullmatch(r"[0-9]{2,6}", announce_ext):
            log(f"announce: invalid announce_ext {announce_ext!r}; dial code disabled")
        elif announce_ext in reserved:
            log(f"announce: announce_ext {announce_ext} collides with a reserved/room ext; dial code disabled")
        else:
            parts += [
                f"exten = {announce_ext},1,NoOp(Announce)",
                " same = n,Goto(announce,s,1)",
                "",
            ]
            reserved.add(announce_ext)

    if exts:
        joined = "|".join(exts)
        parts += [
            "exten = _X.,1,NoOp(Room call to ${EXTEN})",
            f" same = n,GotoIf($[\"${{EXTEN}}\" : \"^({joined})$\"]?dial:invalid)",
            " same = n(dial),Dial(PJSIP/${EXTEN},30,rtT)",
            " same = n,Hangup()",
            # Generated congestion tone (no prompt sound file required).
            " same = n(invalid),Congestion(5)",
            " same = n,Hangup()",
            "",
        ]
        # Outbound-via-trunk rules belong in [rooms] (alongside the room pattern)
        # so the phones can actually reach them; _<prefix>. out-prioritises _X.
        if trunk.get("enabled"):
            parts += render_outbound_rules(prefix, caller_id)

    if operator_on and exts:
        parts += render_operator_context("|".join(exts), automation_on, mwi_on)

    # The [wakeup]/[wakeup-deliver] contexts exist whenever wake-ups are on, even
    # if the dial code collided (the scheduler still delivers into wakeup-deliver).
    if wakeup_on and exts:
        parts += render_wakeup_context()

    # The [page] context exists whenever paging is on even if its dial code
    # collided — ami.page_all Originates each room INTO it to start the intercom.
    if page_on and exts:
        parts += render_page_context()

    # The [automation] context exists whenever automation is on even if its dial
    # code collided — the operator routes a spoken "automation" Goto(automation,s,1).
    if automation_on and exts:
        parts += render_automation_context()

    # Dial-a-status menu + phone->speaker announce contexts.
    if status_on and exts:
        parts += render_status_context()
    if announce_on and exts:
        parts += render_announce_context()

    # Inbound from the trunk gets its OWN [from-trunk] context. (Outbound rules are
    # emitted up in [rooms] via render_outbound_rules — they must not live here, or
    # they'd land in this inbound context and never match a phone's dialed number.)
    if trunk.get("enabled") and exts:
        # Where an incoming call rings: a comma-separated list of configured room
        # exts (trunk.inbound_ext, e.g. "19,20" = cordless + iPhone), a single ext
        # ("19"), or empty = every room. Each listed ext must pass the same
        # validation as rooms and be a known room; a bad token is dropped + logged
        # so a typo never silently drops the call, and a fully-invalid list falls
        # back to ringing the whole house.
        ring_exts: list[str] = []
        for tok in str(trunk.get("inbound_ext", "") or "").split(","):
            tok = tok.strip()
            if not tok:
                continue
            if not re.fullmatch(r"[0-9]{2,6}", tok):
                log(f"trunk: inbound_ext entry {tok!r} is not a valid ext; dropping")
                continue
            if tok not in exts:
                log(f"trunk: inbound_ext entry {tok!r} is not a room ext; dropping")
                continue
            if tok not in ring_exts:  # preserve order, drop dups
                ring_exts.append(tok)
        if not ring_exts:  # blank or every token invalid -> ring the whole house
            ring_exts = list(exts)
        explicit = ring_exts != list(exts)
        dial_target = "&".join(f"PJSIP/{e}" for e in ring_exts)
        where = ("ring " + ",".join(ring_exts)) if explicit else "ring every room"
        parts += [
            ";; ----- Inbound from the trunk -----",
            "[from-trunk]",
            f"exten = _X.,1,NoOp(Inbound call ${{EXTEN}} -> {where})",
            f" same = n,Dial({dial_target},30,rtT)",
            " same = n,Hangup()",
            "exten = s,1,NoOp(Inbound call, no DID)",
            f" same = n,Dial({dial_target},30,rtT)",
            " same = n,Hangup()",
            "",
        ]

    return "\n".join(parts) + "\n"


# --------------------------------------------------------------------------- #
# confbridge.conf  (intercom conference profiles for the page-all feature)
# --------------------------------------------------------------------------- #
def render_confbridge() -> str:
    """Minimal, quiet ConfBridge profiles for the house page intercom.

    The [page] context joins every ringing room into this bridge. We want a
    barge-in intercom, not a meeting: no music-on-hold, no join/leave beeps or
    name prompts, no "you are the only person" announcement — just open audio.
    """
    return "\n".join([
        ";; GENERATED by switchboard-config — edits here are overwritten.",
        "",
        "[switchboard_bridge]",
        "type = bridge",
        "max_members = 0",            # unlimited; the whole house can join
        "record_conference = no",
        "",
        "[switchboard_user]",
        "type = user",
        "quiet = yes",                # suppress system prompts/tones to the user
        "announce_join_leave = no",   # no join/leave name announcements
        "announce_only_user = no",    # no "you are the only person" spam
        "music_on_hold_when_empty = no",
        "wait_marked = no",
        "end_marked = no",
        "dtmf_passthrough = yes",
        "",
    ]) + "\n"


# --------------------------------------------------------------------------- #
# modules.conf  (load the right MWI/intercom modules)
# --------------------------------------------------------------------------- #
def render_modules(opts: dict) -> str:
    """Generate modules.conf so the features' modules are definitely loaded.

    Everything autoloads, but we explicitly load the three modules the new
    features rely on so a missing one is obvious in the log rather than a silent
    "unknown command": **res_pjsip_notify** (the PJSIPNotify AMI action that
    sends the message-waiting NOTIFY — the FXS stutter tone), and
    **app_confbridge** / **app_page** (the page-all intercom). A failed explicit
    load is non-fatal. NOTE: res_mwi_external (MWIUpdate) is NOT built into the
    Alpine Asterisk package, which is why MWI goes via PJSIPNotify instead.
    """
    lines = [
        ";; GENERATED by switchboard-config — edits here are overwritten.",
        "[modules]",
        "autoload = yes",
        "",
        ";; Message-waiting NOTIFY (stutter tone) + page-all intercom.",
        "load = res_pjsip_notify.so",
        "load = app_confbridge.so",
        "load = app_page.so",
        "",
    ]
    return "\n".join(lines) + "\n"


# --------------------------------------------------------------------------- #
# pjsip_notify.conf  (message-waiting NOTIFY templates for the MWI feature)
# --------------------------------------------------------------------------- #
def render_pjsip_notify() -> str:
    """NOTIFY templates the PJSIPNotify AMI action sends to a room's contact.

    A ``message-summary`` event with ``Messages-Waiting: yes`` is the standard
    unsolicited-MWI NOTIFY; the Grandstream renders it as a stutter dial tone
    (with its "MWI -> stutter" port setting on). "no" clears it. ami.set_mwi
    picks the on/off template by name.
    """
    return "\n".join([
        ";; GENERATED by switchboard-config — edits here are overwritten.",
        "",
        "[switchboard-mwi-on]",
        "Event=message-summary",
        "Content-type=application/simple-message-summary",
        "Content=Messages-Waiting: yes",
        "Content+=Voice-Message: 1/0 (0/0)",
        "",
        "[switchboard-mwi-off]",
        "Event=message-summary",
        "Content-type=application/simple-message-summary",
        "Content=Messages-Waiting: no",
        "Content+=Voice-Message: 0/0 (0/0)",
        "",
    ]) + "\n"


# --------------------------------------------------------------------------- #
# rtp.conf
# --------------------------------------------------------------------------- #
def render_rtp(opts: dict) -> str:
    start = _int(opts.get("rtp_start", 10000) or 10000, 10000)
    end = _int(opts.get("rtp_end", 10200) or 10200, 10200)
    if end <= start:
        log(f"rtp_end ({end}) <= rtp_start ({start}); using {start}-{start + 200}")
        end = start + 200
    return (
        ";; GENERATED by switchboard-config\n"
        "[general]\n"
        f"rtpstart = {start}\n"
        f"rtpend = {end}\n"
    )


# --------------------------------------------------------------------------- #
# manager.conf  (AMI for the Ingress UI, localhost only)
# --------------------------------------------------------------------------- #
def render_manager(ami_user: str, ami_secret: str) -> str:
    return (
        ";; GENERATED by switchboard-config\n"
        "[general]\n"
        "enabled = yes\n"
        "bindaddr = 127.0.0.1\n"
        "port = 5038\n"
        "\n"
        f"[{ami_user}]\n"
        f"secret = {ami_secret}\n"
        "read = system,call,log,verbose,command,agent,user,config,dtmf,reporting,cdr,dialplan\n"
        # The UI runs PJSIPShowEndpoints / PJSIPShowContacts / CoreShowChannels
        # (gated on these *write* classes) and the per-room "test ring" button
        # (AMI Originate, which needs 'originate'; running it with an Application
        # also needs 'system'). The web app constrains Originate to ringing a
        # *known room ext* with a fixed Playback — never Dial — so it can't place
        # an outside call; AMI itself stays loopback-only with a random secret.
        # 'message' is needed for res_mwi_external's MWIUpdate (message-waiting).
        # 'command' (CLI/RCE) is the ONLY class still deliberately withheld.
        "write = system,call,log,verbose,agent,user,config,dtmf,reporting,cdr,dialplan,originate,aoc,security,message\n"
        "permit = 127.0.0.1/255.255.255.255\n"
    )


# --------------------------------------------------------------------------- #
# logger.conf
# --------------------------------------------------------------------------- #
def render_logger(opts: dict) -> str:
    level = str(opts.get("log_level", "info") or "info").strip()
    base = "notice,warning,error"
    if level in ("debug", "trace"):
        base += ",debug,verbose"
    elif level == "info":
        base += ",verbose"
    return (
        ";; GENERATED by switchboard-config\n"
        "[general]\n"
        "\n"
        f"console => {base}\n"
        f"messages => {base}\n"
    )


def render_features() -> str:
    """features.conf — in-call DTMF transfer codes, for the analog (FXS) phones.

    SIP phones (the cordless and the iPhone softphone) transfer with their own
    on-screen Transfer button (SIP REFER, handled natively by chan_pjsip — no
    config needed). The plain analog phones have no transfer button, so they use
    these in-call DTMF feature codes. The room/trunk Dial()s already carry the
    't'/'T' one-touch flags that arm these features for both parties:
      - blind transfer:    ## then the destination ext, then hang up
      - attended transfer: *2 then the destination ext; talk, then hang up to join
    parkext/pickup etc. are intentionally omitted (no parking lot configured).
    """
    return "\n".join([
        ";; GENERATED by switchboard-config — edits here are overwritten.",
        "[general]",
        "[featuremap]",
        "blindxfer => ##",
        "atxfer => *2",
        "",
    ])


def ensure_state_dir() -> None:
    """Create /data/state, owned by the asterisk user, for the runtime JSON stores.

    The wake-up store (wakeup/store.py) and the MWI store (webui/mwi_store.py) are
    written by BOTH the root services (wakeup-scheduler, webui) AND asterisk-user
    processes — the dial-42 wake-up AGI and the dialplan's
    ``System(/usr/bin/switchboard-mwi clear ...)``. Asterisk runs as ``-U asterisk``,
    so those processes must be able to create the flock ``.lock`` and atomic-rename
    temp files NEXT TO the JSON (an os.replace needs write on the containing dir).

    These stores used to live directly in ``/data``, which only root can write — so
    every voice wake-up crashed with ``EPERM`` on ``/data/wakeups.json.lock`` (the
    dial-42 flow fell straight through with NO recording prompt) and the dial-0 MWI
    auto-clear crashed on ``/data/mwi.json.lock``. A dedicated asterisk-owned subdir
    fixes both while leaving the sensitive ``/data/options.json`` root-only. Root
    services keep writing here (root overrides the mode); asterisk owns the dir so
    its os.replace can swap a file the root service last wrote, and vice-versa.

    Runs in the init oneshot as root, BEFORE Asterisk starts. Best-effort migrates a
    pre-existing /data/{wakeups,mwi}.json so a pending wake-up/flag survives the move.
    """
    import shutil
    names = ("wakeups.json", "mwi.json")
    try:
        STATE_DIR.mkdir(parents=True, exist_ok=True)
        # Migrate any pre-existing store from the old root-only /data location.
        for name in names:
            old, new = DATA_DIR / name, STATE_DIR / name
            if old.exists() and not new.exists():
                try:
                    old.replace(new)  # same filesystem under /data
                except OSError as exc:
                    log(f"WARNING: could not migrate {name} into state dir: {exc}")
        # Pre-create the JSON + flock files so they exist group-writable BEFORE any
        # service opens them. The lock is opened in append mode (needs write on the
        # FILE), and an atomic write leaves the JSON owned by whichever user wrote
        # last — so without a shared group both the root services and the asterisk
        # user would lock each other out. setgid on the dir makes new temp/lock files
        # inherit the asterisk group; 0664 keeps them group-writable.
        for name in names:
            p = STATE_DIR / name
            if not p.exists():
                p.write_text("{}")
            lock = STATE_DIR / (name + ".lock")
            if not lock.exists():
                lock.write_text("")
        # chmod FIRST (always works as root) so an absent asterisk user off-box can't
        # leave the modes unset; then hand the dir + files to the asterisk user.
        os.chmod(STATE_DIR, 0o2775)  # setgid → children inherit the asterisk group
        for f in STATE_DIR.iterdir():
            try:
                os.chmod(f, 0o664)
            except OSError:
                pass
        try:
            shutil.chown(STATE_DIR, user="asterisk", group="asterisk")
            for f in STATE_DIR.iterdir():
                shutil.chown(f, user="asterisk", group="asterisk")
        except (LookupError, KeyError, PermissionError, OSError) as exc:
            log(f"WARNING: could not chown state dir to asterisk: {exc}")
    except (PermissionError, LookupError, KeyError, OSError) as exc:
        # The init oneshot is root, so this normally succeeds; warn (don't crash)
        # if something is off — the rest of the config still renders.
        log(f"WARNING: could not prepare asterisk-writable state dir: {exc}")
    # Surface a silent setup failure LOUDLY: if the dir isn't group-writable, the
    # asterisk-user wake-up AGI + MWI-clear will EACCES again exactly as before, and
    # the only other signal would be a single buried WARNING. Rare (init is root,
    # /data is always mounted, and this re-runs idempotently every boot), but worth
    # an ERROR line so it can't masquerade as a healthy boot.
    try:
        mode = STATE_DIR.stat().st_mode
        if not (STATE_DIR.is_dir() and (mode & 0o020)):
            log(f"ERROR: /data/state not group-writable (mode {oct(mode)}); dial-42 "
                "wake-up + dial-0 MWI-clear may fail with permission denied")
    except OSError:
        log("ERROR: /data/state missing after setup; dial-42 wake-up + dial-0 "
            "MWI-clear may fail with permission denied")


def write_operator_runtime(opts: dict) -> None:
    """Stage the voice-operator runtime, when enabled.

    Creates an ``asterisk``-writable ASR scratch dir under /run (tmpfs: fast, no
    SD-card wear, auto-cleared) and writes a sanitized rooms map the STT wrapper
    reads — so the recognizer shares the generator's already-validated room list
    (single source of truth) instead of re-parsing raw options.json. Synonyms
    come from the optional ``operator_synonyms`` option.
    """
    if not (opts.get("operator") or {}).get("enabled", True):
        return
    asr_dir = RUN_DIR / "asr"
    asr_dir.mkdir(parents=True, exist_ok=True)
    # Announcement audio: the asterisk-user announce AGI writes the combined WAV
    # here; the (root) webui serves it over the LAN for the media players. 0755 so
    # the webui can read it whatever user it runs as.
    announce_dir = RUN_DIR / "announce"
    announce_dir.mkdir(parents=True, exist_ok=True)

    synonyms: dict[str, list[str]] = {}
    for entry in (opts.get("operator_synonyms") or []):
        ext = str(entry.get("ext", "")).strip()
        phrases = [str(p).strip() for p in (entry.get("phrases") or []) if str(p).strip()]
        if ext and phrases:
            synonyms.setdefault(ext, []).extend(phrases)

    payload = {
        # opts["rooms"] is already valid_rooms()-validated by main().
        "rooms": [{"ext": r["ext"], "name": r["name"]} for r in (opts.get("rooms") or [])],
        "synonyms": synonyms,
        "threshold": 0.6,
    }
    op_path = RUN_DIR / "operator.json"
    op_path.write_text(json.dumps(payload))
    try:
        import shutil
        shutil.chown(asr_dir, user="asterisk", group="asterisk")
        os.chmod(asr_dir, 0o750)
        shutil.chown(announce_dir, user="asterisk", group="asterisk")
        os.chmod(announce_dir, 0o755)
        shutil.chown(op_path, user="asterisk", group="asterisk")
        os.chmod(op_path, 0o640)
    except (PermissionError, LookupError, KeyError, OSError) as exc:
        # The init oneshot runs as root before Asterisk starts, so this normally
        # succeeds; warn (don't crash) if the asterisk user isn't present yet.
        log(f"WARNING: could not set asterisk ownership on operator runtime: {exc}")
    log(f"operator: staged {len(payload['rooms'])} room(s) for voice recognition")


_EID_RE = re.compile(r"^[a-z_]+\.[a-z0-9_]+$")


def _clean_eid(val: str, domains: tuple = ()) -> str:
    """A well-formed entity_id — optionally restricted to the given domain(s) — or
    '' (drops anything malformed / wrong-domain before it's staged for an AGI, so a
    mistyped `homeassistant.restart` or `shell_command.x` can never reach HA)."""
    s = str(val or "").strip()
    if not _EID_RE.match(s):
        return ""
    if domains and s.split(".", 1)[0] not in domains:
        return ""
    return s


def write_features_runtime(opts: dict) -> None:
    """Stage the HA-integrated voice-feature settings (smart wake-up + announce)
    for the AGIs, which run as the asterisk user and CANNOT read root-only
    /data/options.json. Written to /run/switchboard/features.json (tmpfs,
    asterisk-readable). Entity ids are validated here as defence in depth."""
    players = [e for e in (_clean_eid(p, ("media_player",)) for p in (opts.get("announce_players") or [])) if e]
    payload = {
        "wakeup": {
            "scene": _clean_eid(opts.get("wakeup_scene", ""), ("scene",)),
            "weather": bool(opts.get("wakeup_weather", True)),
            "calendar": _clean_eid(opts.get("wakeup_calendar", ""), ("calendar",)),
        },
        "announce": {
            "players": players,
            "tts_engine": _clean_eid(opts.get("announce_tts_engine", "tts.piper"), ("tts",)) or "tts.piper",
        },
    }
    fp = RUN_DIR / "features.json"
    fp.write_text(json.dumps(payload))
    try:
        import shutil
        shutil.chown(fp, user="asterisk", group="asterisk")
        os.chmod(fp, 0o640)
    except (PermissionError, LookupError, KeyError, OSError) as exc:
        log(f"WARNING: could not set asterisk ownership on features runtime: {exc}")
    w = payload["wakeup"]
    log(f"features: wake-up(scene={'set' if w['scene'] else 'none'}, weather={w['weather']}, "
        f"calendar={'set' if w['calendar'] else 'none'}), announce({len(players)} player(s))")


def main() -> None:
    opts = load_options()
    # Validate/sanitize/dedupe rooms once; both renderers consume the cleaned list.
    opts["rooms"] = valid_rooms(opts.get("rooms", []) or [])
    if not opts["rooms"]:
        log("WARNING: no valid rooms configured — no phones will register")
    ASTERISK_ETC.mkdir(parents=True, exist_ok=True)
    RUN_DIR.mkdir(parents=True, exist_ok=True)
    # Make /data/state asterisk-writable BEFORE Asterisk starts, so the dial-42
    # wake-up AGI and the dialplan's MWI-clear (both run as the asterisk user) can
    # write their JSON stores instead of crashing with EPERM.
    ensure_state_dir()
    # Set the container's local time before Asterisk/console start, so the
    # talking clock and console clock read local time.
    tz = apply_timezone(resolve_timezone(opts))
    (RUN_DIR / "tz").write_text(tz + "\n")
    write_operator_runtime(opts)
    write_features_runtime(opts)

    ami_user = "switchboard"
    ami_secret = gen_secret()

    write(ASTERISK_ETC / "pjsip.conf", render_pjsip(opts))
    write(ASTERISK_ETC / "extensions.conf", render_extensions(opts))
    write(ASTERISK_ETC / "confbridge.conf", render_confbridge())
    write(ASTERISK_ETC / "modules.conf", render_modules(opts))
    write(ASTERISK_ETC / "pjsip_notify.conf", render_pjsip_notify())
    write(ASTERISK_ETC / "rtp.conf", render_rtp(opts))
    write(ASTERISK_ETC / "manager.conf", render_manager(ami_user, ami_secret))
    write(ASTERISK_ETC / "logger.conf", render_logger(opts))
    write(ASTERISK_ETC / "features.conf", render_features())

    env_path = RUN_DIR / "ami.env"
    env_path.write_text(f"AMI_USER={ami_user}\nAMI_SECRET={ami_secret}\n")
    os.chmod(env_path, 0o600)
    log(f"wrote {env_path}")

    n_rooms = len(opts.get("rooms", []) or [])
    trunk_on = bool((opts.get("trunk") or {}).get("enabled"))
    log("codecs: u-law only (no transcoding)")
    log(f"done: {n_rooms} room(s), trunk={'on' if trunk_on else 'off'}")


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""Render Asterisk configuration for Switchboard from the add-on options.

The add-on options (/data/options.json) are the single source of truth. On every
start we regenerate /etc/asterisk/{pjsip,extensions,rtp,manager,logger}.conf so
the running PBX always matches the declared config.

Design notes
------------
* PJSIP only. chan_sip is removed in modern Asterisk; every endpoint and the
  optional trunk are res_pjsip.
* Analog FXS ports register *to* us, so each room is a PJSIP endpoint with a
  dynamic AOR and inbound auth.
* Codecs are configurable (``codecs`` option). The order is the preference
  order Asterisk offers. The sensible default puts G.711 ulaw first — best for
  the narrowband analog handsets and avoids transcoding — while still offering
  g722/opus so HD-capable or IP endpoints can negotiate up. (Opus carries no
  extra fidelity from an antique analog handset; it matters between IP
  endpoints.)
* AMI is bound to 127.0.0.1 only and used by the Ingress UI for live status.
"""

from __future__ import annotations

import json
import os
import secrets
import string
from pathlib import Path

OPTIONS_PATH = Path("/data/options.json")
ASTERISK_ETC = Path("/etc/asterisk")
RUN_DIR = Path("/run/switchboard")

# Codecs we know how to emit. slin16 = wideband linear (handy for IP/HD).
KNOWN_CODECS = ("ulaw", "alaw", "g722", "opus", "g729", "gsm", "slin16")
DEFAULT_CODECS = ("ulaw", "alaw", "g722", "opus")


def log(msg: str) -> None:
    print(f"[switchboard-config] {msg}", flush=True)


def load_options() -> dict:
    if not OPTIONS_PATH.exists():
        log(f"WARNING: {OPTIONS_PATH} missing; using empty defaults")
        return {}
    with OPTIONS_PATH.open() as fh:
        return json.load(fh)


def gen_secret(n: int = 24) -> str:
    alphabet = string.ascii_letters + string.digits
    return "".join(secrets.choice(alphabet) for _ in range(n))


def write(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    log(f"wrote {path} ({len(content)} bytes)")


def codec_allow(opts: dict) -> str:
    """Build the PJSIP ``allow`` line from the configured codec preference."""
    wanted = opts.get("codecs") or list(DEFAULT_CODECS)
    chosen = [c for c in wanted if c in KNOWN_CODECS]
    if not chosen:
        chosen = list(DEFAULT_CODECS)
    return "!all," + ",".join(chosen)


# --------------------------------------------------------------------------- #
# pjsip.conf
# --------------------------------------------------------------------------- #
def render_pjsip(opts: dict) -> str:
    rooms = opts.get("rooms", []) or []
    trunk = opts.get("trunk", {}) or {}
    allow = codec_allow(opts)

    parts = [
        ";; GENERATED by switchboard-config — edits here are overwritten.",
        "",
        "[transport-udp]",
        "type = transport",
        "protocol = udp",
        "bind = 0.0.0.0:5060",
        "",
        ";; ----- Endpoint template shared by all room phones -----",
        "[room-endpoint](!)",
        "type = endpoint",
        "context = rooms",
        f"allow = {allow}",
        "direct_media = no",          # keep media through Asterisk (NAT-safe on LAN)
        "rtp_symmetric = yes",
        "force_rport = yes",
        "rewrite_contact = yes",      # ATAs on the LAN; trust the source port
        "dtmf_mode = rfc4733",
        "",
        "[room-aor](!)",
        "type = aor",
        "max_contacts = 1",
        "remove_existing = yes",
        "qualify_frequency = 60",
        "",
    ]

    for room in rooms:
        ext = str(room.get("ext", "")).strip()
        name = str(room.get("name", ext)).strip()
        sec = str(room.get("secret", "")).strip()
        if not ext or not sec:
            log(f"skipping room with missing ext/secret: {room!r}")
            continue
        parts += [
            f";; Room {ext} — {name}",
            f"[{ext}](room-aor)",
            "type = aor",
            "",
            f"[{ext}-auth]",
            "type = auth",
            "auth_type = userpass",
            f"username = {ext}",
            f"password = {sec}",
            "",
            f"[{ext}](room-endpoint)",
            "type = endpoint",
            f"auth = {ext}-auth",
            f"aors = {ext}",
            f'callerid = "{name}" <{ext}>',
            "",
        ]

    if trunk.get("enabled"):
        parts += render_trunk_pjsip(trunk, allow)

    return "\n".join(parts) + "\n"


def render_trunk_pjsip(trunk: dict, allow: str) -> list[str]:
    host = str(trunk.get("provider_host", "")).strip()
    port = int(trunk.get("port", 5060) or 5060)
    user = str(trunk.get("username", "")).strip()
    sec = str(trunk.get("secret", "")).strip()
    from_user = str(trunk.get("from_user", "") or user).strip()
    from_domain = str(trunk.get("from_domain", "") or host).strip()
    do_register = bool(trunk.get("registns", True))

    if not host or not user:
        log("trunk enabled but provider_host/username missing — skipping trunk")
        return []

    lines = [
        ";; ----- SIP trunk (outside line) -----",
        "[trunk-auth]",
        "type = auth",
        "auth_type = userpass",
        f"username = {user}",
        f"password = {sec}",
        "",
        "[trunk-aor]",
        "type = aor",
        f"contact = sip:{host}:{port}",
        "qualify_frequency = 60",
        "",
        "[trunk]",
        "type = endpoint",
        "context = from-trunk",
        f"allow = {allow}",
        "outbound_auth = trunk-auth",
        "aors = trunk-aor",
        f"from_user = {from_user}",
        f"from_domain = {from_domain}",
        "direct_media = no",
        "rtp_symmetric = yes",
        "force_rport = yes",
        "rewrite_contact = yes",
        "dtmf_mode = rfc4733",
        "",
        "[trunk-identify]",
        "type = identify",
        "endpoint = trunk",
        f"match = {host}",
        "",
    ]
    if do_register:
        lines += [
            "[trunk-reg]",
            "type = registration",
            "transport = transport-udp",
            "outbound_auth = trunk-auth",
            f"server_uri = sip:{host}:{port}",
            f"client_uri = sip:{user}@{from_domain}",
            "retry_interval = 60",
            "",
        ]
    return lines


# --------------------------------------------------------------------------- #
# extensions.conf  (dial plan)
# --------------------------------------------------------------------------- #
def render_extensions(opts: dict) -> str:
    rooms = opts.get("rooms", []) or []
    trunk = opts.get("trunk", {}) or {}
    exts = [str(r.get("ext", "")).strip() for r in rooms if r.get("ext")]
    prefix = str(trunk.get("dial_prefix", "9") or "9").strip()
    caller_id = str(trunk.get("outbound_caller_id", "") or "").strip()

    parts = [
        ";; GENERATED by switchboard-config — edits here are overwritten.",
        "",
        "[general]",
        "static = yes",
        "writeprotect = yes",
        "",
        "[globals]",
        "",
        ";; ----- Room-to-room calling -----",
        "[rooms]",
    ]

    if exts:
        joined = "|".join(exts)
        parts += [
            "exten = _X.,1,NoOp(Room call to ${EXTEN})",
            f" same = n,GotoIf($[\"${{EXTEN}}\" : \"^({joined})$\"]?dial:invalid)",
            " same = n(dial),Dial(PJSIP/${EXTEN},30,rtT)",
            " same = n,Hangup()",
            " same = n(invalid),Playback(invalid)",
            " same = n,Hangup()",
            "",
        ]

    if trunk.get("enabled"):
        cid = f"Set(CALLERID(num)={caller_id})" if caller_id else "NoOp(no outbound CID)"
        parts += [
            ";; ----- Outbound via SIP trunk -----",
            f"exten = _{prefix}.,1,NoOp(Outbound ${{EXTEN:1}})",
            f" same = n,{cid}",
            " same = n,Dial(PJSIP/${EXTEN:1}@trunk,60,rtT)",
            " same = n,Hangup()",
            "",
            ";; ----- Inbound from the trunk: ring every room -----",
            "[from-trunk]",
        ]
        if exts:
            dial_all = "&".join(f"PJSIP/{e}" for e in exts)
            parts += [
                "exten = _X.,1,NoOp(Inbound call ${EXTEN})",
                f" same = n,Dial({dial_all},30,rtT)",
                " same = n,Hangup()",
                "exten = s,1,NoOp(Inbound call, no DID)",
                f" same = n,Dial({dial_all},30,rtT)",
                " same = n,Hangup()",
                "",
            ]

    return "\n".join(parts) + "\n"


# --------------------------------------------------------------------------- #
# rtp.conf
# --------------------------------------------------------------------------- #
def render_rtp(opts: dict) -> str:
    start = int(opts.get("rtp_start", 10000) or 10000)
    end = int(opts.get("rtp_end", 10200) or 10200)
    if end <= start:
        end = start + 200
    return (
        ";; GENERATED by switchboard-config\n"
        "[general]\n"
        f"rtpstart = {start}\n"
        f"rtpend = {end}\n"
    )


# --------------------------------------------------------------------------- #
# manager.conf  (AMI for the Ingress UI, localhost only)
# --------------------------------------------------------------------------- #
def render_manager(ami_user: str, ami_secret: str) -> str:
    return (
        ";; GENERATED by switchboard-config\n"
        "[general]\n"
        "enabled = yes\n"
        "bindaddr = 127.0.0.1\n"
        "port = 5038\n"
        "\n"
        f"[{ami_user}]\n"
        f"secret = {ami_secret}\n"
        "read = system,call,log,verbose,command,agent,user,config,dtmf,reporting,cdr,dialplan\n"
        "write = system,call,command,reporting,originate\n"
        "permit = 127.0.0.1/255.255.255.255\n"
    )


# --------------------------------------------------------------------------- #
# logger.conf
# --------------------------------------------------------------------------- #
def render_logger(opts: dict) -> str:
    level = str(opts.get("log_level", "info") or "info").strip()
    base = "notice,warning,error"
    if level in ("debug", "trace"):
        base += ",debug,verbose"
    elif level == "info":
        base += ",verbose"
    return (
        ";; GENERATED by switchboard-config\n"
        "[general]\n"
        "\n"
        f"console => {base}\n"
        f"messages => {base}\n"
    )


def main() -> None:
    opts = load_options()
    ASTERISK_ETC.mkdir(parents=True, exist_ok=True)
    RUN_DIR.mkdir(parents=True, exist_ok=True)

    ami_user = "switchboard"
    ami_secret = gen_secret()

    write(ASTERISK_ETC / "pjsip.conf", render_pjsip(opts))
    write(ASTERISK_ETC / "extensions.conf", render_extensions(opts))
    write(ASTERISK_ETC / "rtp.conf", render_rtp(opts))
    write(ASTERISK_ETC / "manager.conf", render_manager(ami_user, ami_secret))
    write(ASTERISK_ETC / "logger.conf", render_logger(opts))

    env_path = RUN_DIR / "ami.env"
    env_path.write_text(f"AMI_USER={ami_user}\nAMI_SECRET={ami_secret}\n")
    os.chmod(env_path, 0o600)
    log(f"wrote {env_path}")

    n_rooms = len(opts.get("rooms", []) or [])
    trunk_on = bool((opts.get("trunk") or {}).get("enabled"))
    log(f"codecs: {codec_allow(opts)}")
    log(f"done: {n_rooms} room(s), trunk={'on' if trunk_on else 'off'}")


if __name__ == "__main__":
    main()

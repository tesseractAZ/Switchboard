#!/usr/bin/python3
"""Switchboard operator — offline speech-to-text wrapper.

The one and only place the recognizer is invoked, behind a fixed contract so the
call-control layer (the AGI) stays 100% stdlib and engine-agnostic:

    switchboard-stt --in <recorded.wav>   ->   prints a room extension (or nothing)

Engine: whisper.cpp (built from source in the add-on image; musl-native, unlike
Vosk whose only Linux wheels are glibc manylinux). whisper.cpp wants 16 kHz mono
WAV; Asterisk records the 8 kHz telephone channel, so we resample here with the
stdlib (audioop, linear fallback) — no sox/ffmpeg dependency. Recognition is
biased toward the configured room names via whisper's --prompt, then the result
is resolved to an extension by the shared, unit-tested matcher.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import tempfile
import warnings
import wave

# audioop (used for 8k->16k resampling) is deprecation-warned on py3.12 but is
# the right stdlib tool on the Alpine base; silence the warning so each call
# doesn't spam the Asterisk log.
warnings.filterwarnings("ignore", category=DeprecationWarning)

sys.path.insert(0, "/usr/share/switchboard/operator")
import match as matcher  # noqa: E402  (shared, unit-tested room matcher)
# Pure automation-intent gate. Best-effort: rooms mode still resolves rooms even
# if this can't import (it just won't short-circuit to the automation flow).
try:
    import lights_match  # noqa: E402
except Exception:  # noqa: BLE001
    lights_match = None

WHISPER_BIN = os.environ.get("SW_WHISPER_BIN", "/usr/bin/whisper-cli")
WHISPER_MODEL = os.environ.get("SW_WHISPER_MODEL", "/usr/share/whisper/model.bin")
OPERATOR_JSON = "/run/switchboard/operator.json"


def log(msg: str) -> None:
    sys.stderr.write(f"[switchboard-stt] {msg}\n")


def load_operator() -> dict:
    try:
        with open(OPERATOR_JSON) as fh:
            return json.load(fh)
    except (OSError, ValueError) as exc:
        log(f"cannot read {OPERATOR_JSON}: {exc}")
        return {"rooms": [], "synonyms": {}, "threshold": 0.6}


def _linear_resample(data: bytes, in_rate: int, out_rate: int) -> bytes:
    """Mono 16-bit linear resampler — fallback if audioop is unavailable."""
    import array
    if in_rate == out_rate:
        return data
    src = array.array("h")
    src.frombytes(data)
    ratio = out_rate / in_rate
    out_len = int(len(src) * ratio)
    out = array.array("h", bytes(2 * out_len))
    for i in range(out_len):
        pos = i / ratio
        j = int(pos)
        frac = pos - j
        a = src[j] if j < len(src) else 0
        b = src[j + 1] if j + 1 < len(src) else a
        out[i] = int(a + (b - a) * frac)
    return out.tobytes()


def to_16k_wav(src_path: str, dst_path: str) -> bool:
    """Read Asterisk's recorded WAV and write a 16 kHz mono 16-bit WAV for whisper."""
    try:
        with wave.open(src_path, "rb") as w:
            nch, sw, fr = w.getnchannels(), w.getsampwidth(), w.getframerate()
            data = w.readframes(w.getnframes())
    except (OSError, wave.Error) as exc:
        log(f"cannot read recording {src_path}: {exc}")
        return False
    if not data:
        return False
    try:
        import audioop  # deprecated in 3.13+, present on Alpine 3.21's py3.12
        if nch == 2:
            data = audioop.tomono(data, sw, 0.5, 0.5)
        if sw != 2:
            data = audioop.lin2lin(data, sw, 2)
        if fr != 16000:
            data, _ = audioop.ratecv(data, 2, 1, fr, 16000, None)
    except Exception as exc:  # noqa: BLE001  (any audioop issue -> linear path)
        log(f"audioop unavailable ({exc}); using linear resampler")
        data = _linear_resample(data, fr, 16000)
    with wave.open(dst_path, "wb") as w:
        w.setnchannels(1)
        w.setsampwidth(2)
        w.setframerate(16000)
        w.writeframes(data)
    return True


_BRACKET = re.compile(r"\[[^\]]*\]|\([^)]*\)")  # [BLANK_AUDIO], (speaking), etc.


def transcribe(wav16: str, prompt: str) -> str:
    cmd = [
        WHISPER_BIN, "-m", WHISPER_MODEL, "-f", wav16,
        "-l", "en", "-nt", "-bs", "1",
        "-t", str(min(4, os.cpu_count() or 2)),
    ]
    if prompt:
        cmd += ["--prompt", prompt]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=20)
    except (subprocess.TimeoutExpired, OSError) as exc:
        log(f"whisper failed: {exc}")
        return ""
    text = _BRACKET.sub(" ", proc.stdout or "")
    return " ".join(text.split()).strip()


def _recording_to_text(infile: str, prompt: str) -> str:
    """Resample the recording to 16 kHz and transcribe it. Shared by both modes."""
    with tempfile.NamedTemporaryFile(suffix=".wav", dir="/run/switchboard/asr",
                                     delete=False) as tf:
        wav16 = tf.name
    try:
        if not to_16k_wav(infile, wav16):
            return ""
        return transcribe(wav16, prompt)
    finally:
        try:
            os.unlink(wav16)
        except OSError:
            pass


# Time vocabulary to bias whisper for the wake-up flow.
_TIME_PROMPT = ("A time of day, for example: seven a.m., six thirty, "
                "quarter past seven, ten forty five, half past six, noon, midnight.")


def resolve_rooms_text(text: str, rooms: list, synonyms: dict | None = None,
                       threshold: float = 0.6) -> str:
    """Pure rooms-mode decision (importable for tests, no I/O).

    A single transcript decides between the home-automation flow and a room
    connection so the operator only runs whisper ONCE:

      * a clear automation/lights request  -> the literal token 'automation'
      * a recognized room name             -> that room's extension
      * anything else                      -> '' (no match)

    The automation check is intentionally conservative (lights_match keeps it so)
    so an ordinary room name like "garage"/"office" still resolves to its ext."""
    if lights_match is not None and lights_match.is_automation_request(text):
        return "automation"
    ext, _score, _reason = matcher.match(text, rooms, synonyms or {}, threshold)
    return ext or ""


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--in", dest="infile", required=True)
    ap.add_argument("--mode", default="rooms", choices=["rooms", "time", "transcribe"])
    # Optional whisper --prompt bias (space-separated words) — used by the
    # home-automation flow to seed light/area vocabulary for better recognition.
    ap.add_argument("--bias", default="")
    args = ap.parse_args()

    if args.mode == "transcribe":
        # Raw transcript only — no room/time resolution. The home-automation AGI
        # matches the text itself (area/light/intent) via lights_match.py. The
        # optional --bias seeds whisper's --prompt with the live light/area names.
        prompt = " ".join(args.bias.split())
        text = _recording_to_text(args.infile, prompt)
        log(f"transcribe heard={text!r}")
        if text:
            print(text)
        return 0

    if args.mode == "time":
        # Recognize a spoken time -> "HH:MM" (24h) for the wake-up flow.
        sys.path.insert(0, "/usr/share/switchboard/wakeup")
        import timeparse  # noqa: E402
        text = _recording_to_text(args.infile, _TIME_PROMPT)
        hhmm = timeparse.parse(text)
        if hhmm:
            log(f"heard={text!r} -> time={hhmm}")
            print(hhmm)
        elif re.search(r"\b(cancel|clear|remove|delete|never mind|nevermind|stop|forget)\b", text.lower()):
            log(f"heard={text!r} -> CANCEL")
            print("CANCEL")
        else:
            log(f"heard={text!r} -> time=None")
        return 0

    # rooms mode (the voice operator).
    op = load_operator()
    rooms = op.get("rooms") or []
    synonyms = op.get("synonyms") or {}
    threshold = float(op.get("threshold", 0.6))
    if not rooms:
        log("no rooms configured; nothing to match")
        return 0

    # Bias the recognizer toward the actual room vocabulary.
    vocab = [str(r.get("name", "")) for r in rooms]
    for extras in synonyms.values():
        vocab += list(extras)
    prompt = "Rooms: " + ", ".join(v for v in vocab if v) + "."

    text = _recording_to_text(args.infile, prompt)
    # One whisper pass decides automation-vs-room so the operator AGI doesn't have
    # to transcribe twice: a clear "lights"/"automation" prints the literal token
    # 'automation'; otherwise we resolve the room extension exactly as before.
    result = resolve_rooms_text(text, rooms, synonyms, threshold)
    if result == "automation":
        log(f"heard={text!r} -> automation")
    else:
        log(f"heard={text!r} -> ext={result or None}")
    if result:
        print(result)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

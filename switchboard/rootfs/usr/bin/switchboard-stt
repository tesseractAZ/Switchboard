#!/usr/bin/python3
"""Switchboard operator — offline speech-to-text wrapper.

The one and only place the recognizer is invoked, behind a fixed contract so the
call-control layer (the AGI) stays 100% stdlib and engine-agnostic:

    switchboard-stt --in <recorded.wav>   ->   prints a room extension (or nothing)

Engine: whisper.cpp (built from source in the add-on image; musl-native, unlike
Vosk whose only Linux wheels are glibc manylinux). whisper.cpp wants 16 kHz mono
WAV; Asterisk records the 8 kHz telephone channel, so we resample here with the
stdlib (audioop, linear fallback) — no sox/ffmpeg dependency. Recognition is
biased toward the configured room names via whisper's --prompt, then the result
is resolved to an extension by the shared, unit-tested matcher.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
import tempfile
import warnings
import wave

# audioop (used for 8k->16k resampling) is deprecation-warned on py3.12 but is
# the right stdlib tool on the Alpine base; silence the warning so each call
# doesn't spam the Asterisk log.
warnings.filterwarnings("ignore", category=DeprecationWarning)

sys.path.insert(0, "/usr/share/switchboard/operator")
import match as matcher  # noqa: E402  (shared, unit-tested room matcher)

WHISPER_BIN = os.environ.get("SW_WHISPER_BIN", "/usr/bin/whisper-cli")
WHISPER_MODEL = os.environ.get("SW_WHISPER_MODEL", "/usr/share/whisper/model.bin")
OPERATOR_JSON = "/run/switchboard/operator.json"


def log(msg: str) -> None:
    sys.stderr.write(f"[switchboard-stt] {msg}\n")


def load_operator() -> dict:
    try:
        with open(OPERATOR_JSON) as fh:
            return json.load(fh)
    except (OSError, ValueError) as exc:
        log(f"cannot read {OPERATOR_JSON}: {exc}")
        return {"rooms": [], "synonyms": {}, "threshold": 0.6}


def _linear_resample(data: bytes, in_rate: int, out_rate: int) -> bytes:
    """Mono 16-bit linear resampler — fallback if audioop is unavailable."""
    import array
    if in_rate == out_rate:
        return data
    src = array.array("h")
    src.frombytes(data)
    ratio = out_rate / in_rate
    out_len = int(len(src) * ratio)
    out = array.array("h", bytes(2 * out_len))
    for i in range(out_len):
        pos = i / ratio
        j = int(pos)
        frac = pos - j
        a = src[j] if j < len(src) else 0
        b = src[j + 1] if j + 1 < len(src) else a
        out[i] = int(a + (b - a) * frac)
    return out.tobytes()


def to_16k_wav(src_path: str, dst_path: str) -> bool:
    """Read Asterisk's recorded WAV and write a 16 kHz mono 16-bit WAV for whisper."""
    try:
        with wave.open(src_path, "rb") as w:
            nch, sw, fr = w.getnchannels(), w.getsampwidth(), w.getframerate()
            data = w.readframes(w.getnframes())
    except (OSError, wave.Error) as exc:
        log(f"cannot read recording {src_path}: {exc}")
        return False
    if not data:
        return False
    try:
        import audioop  # deprecated in 3.13+, present on Alpine 3.21's py3.12
        if nch == 2:
            data = audioop.tomono(data, sw, 0.5, 0.5)
        if sw != 2:
            data = audioop.lin2lin(data, sw, 2)
        if fr != 16000:
            data, _ = audioop.ratecv(data, 2, 1, fr, 16000, None)
    except Exception as exc:  # noqa: BLE001  (any audioop issue -> linear path)
        log(f"audioop unavailable ({exc}); using linear resampler")
        data = _linear_resample(data, fr, 16000)
    with wave.open(dst_path, "wb") as w:
        w.setnchannels(1)
        w.setsampwidth(2)
        w.setframerate(16000)
        w.writeframes(data)
    return True


_BRACKET = re.compile(r"\[[^\]]*\]|\([^)]*\)")  # [BLANK_AUDIO], (speaking), etc.


def transcribe(wav16: str, prompt: str) -> str:
    cmd = [
        WHISPER_BIN, "-m", WHISPER_MODEL, "-f", wav16,
        "-l", "en", "-nt", "-bs", "1",
        "-t", str(min(4, os.cpu_count() or 2)),
    ]
    if prompt:
        cmd += ["--prompt", prompt]
    try:
        proc = subprocess.run(cmd, capture_output=True, text=True, timeout=20)
    except (subprocess.TimeoutExpired, OSError) as exc:
        log(f"whisper failed: {exc}")
        return ""
    text = _BRACKET.sub(" ", proc.stdout or "")
    return " ".join(text.split()).strip()


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("--in", dest="infile", required=True)
    args = ap.parse_args()

    op = load_operator()
    rooms = op.get("rooms") or []
    synonyms = op.get("synonyms") or {}
    threshold = float(op.get("threshold", 0.6))
    if not rooms:
        log("no rooms configured; nothing to match")
        return 0

    # Bias the recognizer toward the actual room vocabulary.
    vocab = [str(r.get("name", "")) for r in rooms]
    for extras in synonyms.values():
        vocab += list(extras)
    prompt = "Rooms: " + ", ".join(v for v in vocab if v) + "."

    with tempfile.NamedTemporaryFile(suffix=".wav", dir="/run/switchboard/asr",
                                     delete=False) as tf:
        wav16 = tf.name
    try:
        if not to_16k_wav(args.infile, wav16):
            return 0
        text = transcribe(wav16, prompt)
    finally:
        try:
            os.unlink(wav16)
        except OSError:
            pass

    ext, score, reason = matcher.match(text, rooms, synonyms, threshold)
    log(f"heard={text!r} -> ext={ext} ({reason}, {score})")
    if ext:
        print(ext)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
